{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "/src",
        "/tsconfig.json",
        "/lib",
        "/index.js",
        "/index.js.legacy"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" install --no-audit --no-fund",
        "npm --prefix \"$RESOURCE_DIR\" run compile"
      ]
    }
  ],
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  }
}